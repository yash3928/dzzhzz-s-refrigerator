rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isMember(hid) {
      return signedIn() && request.auth.uid in get(/databases/$(database)/documents/households/$(hid)).data.memberUids;
    }

    match /users/{uid} {
      allow read, create, update: if signedIn() && request.auth.uid == uid;
    }

    match /householdInvites/{code} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /households/{hid} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids == [request.auth.uid];
      allow read: if isMember(hid);
      allow update: if isMember(hid) || (
        signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids'])
        && request.auth.uid in request.resource.data.memberUids
        && exists(/databases/$(database)/documents/householdInvites/$(resource.data.inviteCode))
      );
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      match /ingredients/{itemId} {
        allow read, write: if isMember(hid);
      }
      match /recipes/{recipeId} {
        allow read, write: if isMember(hid);
      }
    }
  }
}
